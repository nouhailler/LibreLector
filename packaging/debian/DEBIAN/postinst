#!/bin/bash
set -e

# Installer les dépendances Python
pip3 install fastapi "uvicorn[standard]" python-multipart \
    ebooklib beautifulsoup4 lxml nltk pydub \
    --break-system-packages --quiet 2>/dev/null || true

# Mettre à jour la base de données des applications .desktop
if command -v update-desktop-database &>/dev/null; then
    update-desktop-database /usr/share/applications 2>/dev/null || true
fi

# Mettre à jour le cache d'icônes
if command -v gtk-update-icon-cache &>/dev/null; then
    gtk-update-icon-cache -f -t /usr/share/icons/hicolor 2>/dev/null || true
fi

echo ""
echo "╔══════════════════════════════════════════════════════════╗"
echo "║          LibreLector v1.0.0 installé avec succès        ║"
echo "╚══════════════════════════════════════════════════════════╝"
echo ""
echo "Lancement : librelector"
echo "  → démarre le serveur local et ouvre http://localhost:7531"
echo ""
echo "Pour la voix neuronale Piper (recommandé) :"
echo ""
echo "  pip3 install piper-tts --break-system-packages"
echo "  mkdir -p ~/.local/share/LibreLector/voices"
echo "  cd ~/.local/share/LibreLector/voices"
echo "  wget https://huggingface.co/rhasspy/piper-voices/resolve/main/fr/fr_FR/siwis/medium/fr_FR-siwis-medium.onnx"
echo "  wget https://huggingface.co/rhasspy/piper-voices/resolve/main/fr/fr_FR/siwis/medium/fr_FR-siwis-medium.onnx.json"
echo ""
echo "Puis dans LibreLector : ⚙ Paramètres → sélectionner le modèle → Enregistrer"
echo ""
