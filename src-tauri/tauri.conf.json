{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LibreLector",
  "version": "1.0.0",
  "identifier": "io.github.nouhailler.librelector",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../ui && npm run dev",
    "beforeBuildCommand": "cd ../ui && npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LibreLector",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "icon": ["icons/32x32.png", "icons/128x128.png"],
    "category": "Utility",
    "shortDescription": "Lecteur EPUB audio-first avec synthèse vocale neuronale",
    "longDescription": "LibreLector est un lecteur de livres numériques conçu pour l'écoute. Il utilise Piper TTS pour des voix neuronales hors-ligne, avec surlignage synchronisé phrase par phrase et export MP3.",
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "python3 (>= 3.11)",
          "ffmpeg"
        ],
        "desktopTemplate": null
      }
    }
  }
}
